# Cloudflare API Credentials for Local CLI Commands
# Duplicate this file as '.env' and fill in your actual values.
# DO NOT commit the '.env' file containing secrets to git.

# Cloudflare API Token (User-scoped with Edit D1 & Edit Workers permissions)
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID (32-character hex string)
CLOUDFLARE_ACCOUNT_ID=

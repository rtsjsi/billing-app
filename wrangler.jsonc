{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "billing-app",
  "main": "worker/index.ts",
  "compatibility_date": "2024-04-03",
  "assets": {
    "directory": "./frontend/dist",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "freelancer-invoices",
      "database_id": "a799c70e-072f-4396-b89b-1b2b9fdb3ca6"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "freelancer-po-attachments"
    }
  ],
  "vars": {
    "JWT_SECRET": "local-dev-jwt-secret-key-change-in-production"
  }
}